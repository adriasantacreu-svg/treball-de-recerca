{
    "latex-workshop.latex.recipes": [
        {
            "name": "latexmk 🔃",
            "tools": [
                "latexmk"
            ]
        }
    ],
    "latex-workshop.latex.tools": [
        {
            "name": "latexmk",
            "command": "latexmk",
            "args": [
                "%DOC%"
            ]
        }
    ],
    "latex-workshop.latex.outDir": "./",
    "latex-workshop.view.pdf.viewer": "tab",
    "latex-workshop.latex.autoBuild.run": "onSave",
    "latex-workshop.latex.clean.enabled": true,
    "latex-workshop.latex.autoClean.run": "onFailed",
    "latex-workshop.latex.rootFile.doNotPrompt": true,
    "latex-workshop.latex.search.rootFiles.enabled": true,
    "latex-workshop.view.pdf.internal.synctex.keybinding": "double-click",
    "latex-workshop.latex.autoBuild.cleanAndRetry.enabled": true,
    
    // --- CONFIGURACIÓ NATIVA DE VS CODE PER A IMATGES (La clau) ---
    "editor.copyPaste.copyExternalFiles": true,
    "editor.dropIntoEditor.enabled": true,
    "editor.dropIntoEditor.showDropSelector": "always",
    "editor.pasteAs.enabled": true,
    "editor.pasteAs.showPasteSelector": "always",
    
    // On es guardaran les fotos quan les enganxis o arrosseguis
    "latex-workshop.bind.enter.key": true
}
